# ---------- Server ----------
NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000
CLIENT_ORIGIN=http://localhost:5173,http://127.0.0.1:5500

# ---------- Database ----------
DATABASE_URL="postgresql://techtribe:techtribe@localhost:5432/techtribe?schema=public"

# ---------- Redis ----------
REDIS_URL="redis://localhost:6379"

# ---------- JWT ----------
JWT_ACCESS_SECRET=replace_with_a_long_random_string_min_32_chars
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ---------- AI (server-side proxy — never expose these keys to the frontend) ----------
# Primary provider — OpenRouter, free-tier models, no card required: https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=openrouter/free
# Optional automatic fallback if OpenRouter is rate-limited or unavailable
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# ---------- Email (SMTP, for verification / password reset) ----------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASSWORD=replace_me
SMTP_FROM="TechTribe <no-reply@techtribe.dev>"

# ---------- Rate limiting ----------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AI_RATE_LIMIT_MAX_PER_DAY=50

# ---------- Bootstrap admin (created by seed script if not present) ----------
ADMIN_EMAIL=admin@techtribe.dev
ADMIN_PASSWORD=ChangeMe123!
ADMIN_USERNAME=admin
